		</div>
		<div class="rounded-box border-base-content/5 bg-base-100 overflow-x-auto border">
			<table class="table">
				<thead>
					<tr>
						<th>Brand</th>
						<th>Name</th>
						<th>Sub-type</th>
						<th>Base price</th>
						<th>Aliases</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					for _, product := range products {
						<tr>
							<td>{ product.Brand }</td>
							<td>{ product.Name }</td>
							<td>{ product.Subtype }</td>
							<td>{ utils.PgNumericToString(product.DefaultPrice, "0.00") } CHF</td>
							<td class="space-x-2">
								for _, alias := range product.Aliases {
									@components.Badge(components.BadgeConfig(alias).Color("primary"))
								}
							</td>
							<td>
								@components.Button(components.ButtonConfig("").
									Icon(icons.Trash()).
									Color("error").
									Style("soft").
									Size("sm").
									HxDelete("/products/" + product.ID.String()).
									HxConfirm("Are you sure you want to delete this product?").
									HxTarget("closest tr").
									HxSwap("delete"),
								)
							</td>
						</tr>
					}
				</tbody>
			</table>
