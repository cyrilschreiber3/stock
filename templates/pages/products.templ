					// 						Style("soft").
					// 						Classes("join-item", "mb-2"),
					// 					)
					// 				</div>
					// 			</template>
					// 		</div>
					// 		@components.Button(components.ButtonConfig("Add alias").
					// 			Icon(icons.Plus()).
					// 			Type("button").
					// 			Color("success").
					// 			Size("sm").
					// 			Style("soft").
					// 			AtClick("aliases.push('')"),
					// 		)
					// 	</div>
					// }
					<div class="modal-action">
						@components.Button(components.ButtonConfig("Close").
							Type("button").
							OnClick("create_product_modal.close()"),
						)
						@components.Button(components.ButtonConfig("Create").
							Type("submit").
							Color("primary"),
